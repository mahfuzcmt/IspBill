<?php
// Copy this file to config.php and fill in the real values.
// config.php is in .gitignore and must never be committed.

define('APP_URL', 'http://your-domain-or-ip:8081');
$_app_stage = 'Dev';   // 'Live' suppresses error output

// ─── Database (netpulse) ───────────────────────────────────────────
$db_host     = 'localhost';     // for Docker compose: 'netpulse-db'
$db_user     = 'netpulse';
$db_password = 'CHANGE_ME';
$db_name     = 'netpulse';

// ─── Database (Radius — same DB unless you split it) ─────────────────
$radius_host = 'localhost';
$radius_user = 'netpulse';
$radius_pass = 'CHANGE_ME';
$radius_name = 'netpulse';

if ($_app_stage != 'Live') {
    error_reporting(E_ERROR);
    ini_set('display_errors', 1);
    ini_set('display_startup_errors', 1);
} else {
    error_reporting(E_ERROR);
    ini_set('display_errors', 0);
    ini_set('display_startup_errors', 0);
}
